<div id="<%= dom_id surf_spot %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Name:</strong>
    <%= surf_spot.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Location:</strong>
    <%= surf_spot.location %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Country:</strong>
    <%= surf_spot.country %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Description:</strong>
    <%= surf_spot.description %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Wave type:</strong>
    <%= surf_spot.wave_type %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Break type:</strong>
    <%= surf_spot.break_type %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Optimal swell direction:</strong>
    <%= surf_spot.optimal_swell_direction %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Optimal wind direction:</strong>
    <%= surf_spot.optimal_wind_direction %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Best tide:</strong>
    <%= surf_spot.best_tide %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Difficulty level:</strong>
    <%= surf_spot.difficulty_level %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Crowd level:</strong>
    <%= surf_spot.crowd_level %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Localism level:</strong>
    <%= surf_spot.localism_level %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Monthly cost:</strong>
    <%= surf_spot.monthly_cost %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Rental cost:</strong>
    <%= surf_spot.rental_cost %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Lesson cost:</strong>
    <%= surf_spot.lesson_cost %>
  </div>
</div>
